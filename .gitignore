# =========================================================
# BrainBerry - Production .gitignore
# =========================================================

# ----------------------------
# Environment variables
# ----------------------------
.env
.env.local
.env.production
.env.development
.env.test
!.env.example

# ----------------------------
# Dependencies
# ----------------------------
node_modules/

# ----------------------------
# Build output
# ----------------------------
dist/
build/
coverage/

# ----------------------------
# Editor / IDE
# ----------------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------------
# Operating System
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------
# Logs
# ----------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ----------------------------
# Temporary files
# ----------------------------
*.tmp
*.bak
scratch/

# ----------------------------
# Docker
# ----------------------------
docker-compose.override.yml

# ----------------------------
# Python cache
# ----------------------------
__pycache__/
*.pyc

# ----------------------------
# Git LFS handles media files
# (Do NOT ignore videos)
# ----------------------------

# ----------------------------
# Files intentionally excluded
# ----------------------------
.gitignore.backup
