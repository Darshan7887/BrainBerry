# ─────────────────────────────────────────────────────────────────
# BrainBerry – Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control!

# Firebase Configuration (client-side keys)
# These identify your Firebase project. Security is enforced via
# Firebase Security Rules, not by hiding these keys.
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Docker Hub (used in CI/CD pipeline)
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_access_token
