rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: only the authenticated user can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sync collection: user can only access their own sync doc
    match /bb_sync/{docId} {
      allow read, write: if request.auth != null;
    }

    // Connection codes: anyone authenticated can read (for validation),
    // only authenticated users can write
    match /bb_connection_codes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
